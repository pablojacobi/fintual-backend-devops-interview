# Production-like environment for docker-compose.prod.yml.
# Copy to .env.prod and edit before `docker compose --profile prod up`.
#
# The fail-closed guards in core/settings_prod.py will refuse to
# start the container if DJANGO_SECRET_KEY is missing or starts with
# `django-insecure-`, or if DJANGO_ALLOWED_HOSTS is empty or contains
# `*`. Use the command shown below to generate a real secret.

# Django
# --------
# Generate a real one with:
#   docker compose --profile prod run --rm web python -c \
#     "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
# Then paste it here.
DJANGO_SECRET_KEY=replace-me-with-the-output-of-get_random_secret_key
DJANGO_DEBUG=0
# Comma-separated. NO `*` (the prod settings will reject it).
DJANGO_ALLOWED_HOSTS=localhost
# INFO in prod; DEBUG only for incident response.
DJANGO_LOG_LEVEL=INFO

# Postgres
# --------
POSTGRES_DB=backend_devops_interview
POSTGRES_USER=postgres
# DO NOT use "postgres" in any non-toy environment. The compose file
# refuses to start without this set, so an empty value here aborts
# the stack at the compose level too.
POSTGRES_PASSWORD=change-me

# Gunicorn (optional overrides; defaults are sensible)
# --------
# GUNICORN_WORKERS=4
# GUNICORN_LOG_LEVEL=info
